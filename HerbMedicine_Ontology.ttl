:caution_ยาขิง_113  rdf:type :Caution ;
    :alertMessage "ไม่แนะนำให้รับประทานในเด็กอายุต่ำกว่า 6 ขวบ"^^xsd:string ;
    :alertSeverity "MEDIUM"^^xsd:string ;
