    rdfs:comment "1. ป้องกันและบรรเทาอาการคลื่นไส้อาเจียนที่มีสาเหตุจากการเมารถเมาเรือ 2. ป้องกันอาการคลื่นไส้อาเจียนหลังการผ่าตัด"^^xsd:string ;
    :treats :symptom_คลื่นไส้ , :symptom_อาเจียน ;
    rdfs:comment "สูตรตำรับไม่ระบุ"^^xsd:string ;
    :hasGuideline :guideline_ยาขิง ;
    :hasSafetyAlert :caution_ยาขิง_111 , :caution_ยาขิง_112 , :caution_ยาขิง_113 , :caution_ยาขิง_114 ;
