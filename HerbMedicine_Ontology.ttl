:guideline_ยาหอมทิพโอสถ_ยาผง  rdf:type :DosageGuideline ;
    :dosageInstruction "รับประทานครั้งละ 1 – 1.4 กรัมละลายน้ำกระสายยาควรดื่มขณะยังอุ่นอยู่เมื่อมีอาการทุก 3 - 4 ชั่วโมงไม่ควรเกินวันละ 3 ครั้งน้ำกระสายยาที่ใช้น้ำดอกไม้หรือน้ำต้มสุกที่ยังอุ่นอยู่"^^xsd:string ;
    :forForm :form_ยาผง_รพ ;
    :minDose "1.0"^^xsd:decimal ;
    :maxDose "1.4"^^xsd:decimal ;
    :hasUnit :unit_กรัม ;
    :hasFrequency :freq_3ครั้งต่อวัน ;
    :hasTiming :timing_เมื่อมีอาการ .

:guideline_ยาหอมทิพโอสถ_ยาเม็ด  rdf:type :DosageGuideline ;
    :dosageInstruction "รับประทานครั้งละ 1 – 1.4 กรัมเมื่อมีอาการทุก 3 - 4 ชั่วโมงไม่ควรเกินวันละ 3 ครั้ง"^^xsd:string ;
    :forForm :form_ยาเม็ด_รพ ;
    :minDose "1.0"^^xsd:decimal ;
    :maxDose "1.4"^^xsd:decimal ;
    :hasUnit :unit_กรัม ;
