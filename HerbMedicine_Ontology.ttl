@prefix :    <http://www.example.org/herbmedicine#> .
@prefix dc:  <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <http://www.example.org/herbmedicine#> .

<http://www.example.org/herbmedicine> rdf:type owl:Ontology ;
                                       dc:description "An OWL ontology for traditional herb medicine knowledge representation, covering formulas, dosage guidelines, safety alerts, and patient conditions." ;
                                       dc:title "Herb Medicine Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/herbmedicine#belongsToGroup
:belongsToGroup rdf:type owl:ObjectProperty ;
                owl:inverseOf :containsMedicine ;
                rdfs:domain :HerbMedicine ;
                rdfs:range :GroupMedicine ;
                rdfs:label "belongs To Group"@en ,
                           "อยู่ในกลุ่มยา"@th .


###  http://www.example.org/herbmedicine#containsMedicine
:containsMedicine rdf:type owl:ObjectProperty ;
                  rdfs:domain :GroupMedicine ;
                  rdfs:range :HerbMedicine ;
                  rdfs:comment "A medicine group contains one or more herb medicines."@en ;
                  rdfs:label "contains Medicine"@en ,
                             "มียาสมุนไพร"@th .


###  http://www.example.org/herbmedicine#forForm
:forForm rdf:type owl:ObjectProperty ;
         rdfs:domain :DosageGuideline ;
         rdfs:range :DosageForm ;
         rdfs:comment "Specifies the dosage form for which the guideline applies."@en ;
         rdfs:label "for Form"@en ,
                    "สำหรับรูปแบบยา"@th .


###  http://www.example.org/herbmedicine#hasComponent
:hasComponent rdf:type owl:ObjectProperty ;
              rdfs:domain :HerbMedicine ;
              rdfs:range :FormulaComponent ;
              rdfs:comment "Relates a herb medicine to its formula components."@en ;
              rdfs:label "has Component"@en ,
                         "มีส่วนประกอบ"@th .


###  http://www.example.org/herbmedicine#hasFrequency
:hasFrequency rdf:type owl:ObjectProperty ;
              rdfs:domain :DosageGuideline ;
              rdfs:range :Frequency ;
              rdfs:label "has Frequency"@en ,
                         "มีความถี่"@th .


###  http://www.example.org/herbmedicine#hasGuideline
:hasGuideline rdf:type owl:ObjectProperty ;
              rdfs:domain :HerbMedicine ;
              rdfs:range :DosageGuideline ;
              rdfs:comment "Links a herb medicine to its dosage guideline."@en ;
              rdfs:label "has Guideline"@en ,
                         "มีแนวทางการใช้ยา"@th .


###  http://www.example.org/herbmedicine#hasSafetyAlert
:hasSafetyAlert rdf:type owl:ObjectProperty ;
                rdfs:domain :HerbMedicine ;
                rdfs:range :SafetyAlert ;
                rdfs:comment "Attaches a safety alert (contraindication or caution) to a herb medicine."@en ;
                rdfs:label "has Safety Alert"@en ,
                           "มีการแจ้งเตือนความปลอดภัย"@th .


###  http://www.example.org/herbmedicine#hasTiming
:hasTiming rdf:type owl:ObjectProperty ;
           rdfs:domain :DosageGuideline ;
           rdfs:range :Timing ;
           rdfs:label "has Timing"@en ,
                      "มีเวลาในการรับประทาน"@th .


###  http://www.example.org/herbmedicine#applicableTo
:applicableTo rdf:type owl:ObjectProperty ;
              rdfs:domain :DosageGuideline ;
              rdfs:range :PatientCondition ;
              rdfs:comment "Links a dosage guideline to the patient condition(s) it applies to, such as age group or physiological state."@en ;
              rdfs:label "applicable To"@en ,
                         "ใช้ได้กับ"@th .


###  http://www.example.org/herbmedicine#hasAgeCondition
:hasAgeCondition rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :applicableTo ;
                 rdfs:domain :DosageGuideline ;
                 rdfs:range :AgeCondition ;
                 rdfs:comment "Specifies the age condition (min/max age) under which this dosage guideline applies."@en ;
                 rdfs:label "has Age Condition"@en ,
                            "มีเงื่อนไขอายุ"@th .


###  http://www.example.org/herbmedicine#hasUnit
:hasUnit rdf:type owl:ObjectProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :DosageGuideline
                                     :FormulaComponent
                                   )
                     ] ;
         rdfs:range :UnitOfMeasurement ;
         rdfs:comment "Associates a unit of measurement with a component or dosage guideline."@en ;
         rdfs:label "has Unit"@en ,
                    "มีหน่วยวัด"@th .


###  http://www.example.org/herbmedicine#treats
:treats rdf:type owl:ObjectProperty ;
        rdfs:domain :HerbMedicine ;
        rdfs:range :MedicalCondition ;
        rdfs:comment "Indicates which medical conditions a herb medicine is used to treat."@en ;
        rdfs:label "treats"@en ,
                   "รักษา"@th .


###  http://www.example.org/herbmedicine#triggeredBy
:triggeredBy rdf:type owl:ObjectProperty ;
             rdfs:domain :SafetyAlert ;
             rdfs:range :PatientCondition ;
             rdfs:comment "A safety alert is triggered by a particular patient condition."@en ;
             rdfs:label "triggered By"@en ,
                        "ถูกกระตุ้นโดย"@th .


###  http://www.example.org/herbmedicine#usePlantPart
:usePlantPart rdf:type owl:ObjectProperty ;
              rdfs:domain :FormulaComponent ;
              rdfs:range :PlantPart ;
              rdfs:comment "Specifies which plant part is used in a formula component."@en ;
              rdfs:label "use Plant Part"@en ,
                         "ใช้ส่วนของพืช"@th .


###  http://www.example.org/herbmedicine#usesHerb
:usesHerb rdf:type owl:ObjectProperty ;
          rdfs:domain :FormulaComponent ;
          rdfs:range :Herb ;
          rdfs:comment "Identifies which herb is used in a formula component."@en ;
          rdfs:label "uses Herb"@en ,
                     "ใช้สมุนไพร"@th .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/herbmedicine#alertMessage
:alertMessage rdf:type owl:DatatypeProperty ;
              rdfs:domain :SafetyAlert ;
              rdfs:range xsd:string ;
              rdfs:label "alert Message"@en ,
                         "ข้อความแจ้งเตือน"@th .


###  http://www.example.org/herbmedicine#alertSeverity
:alertSeverity rdf:type owl:DatatypeProperty ;
               rdfs:domain :SafetyAlert ;
               rdfs:range xsd:string ;
               rdfs:label "alert Severity"@en ,
                          "ระดับความรุนแรง"@th ;
               skos:example "HIGH, MEDIUM, LOW" .


###  http://www.example.org/herbmedicine#allergenName
:allergenName rdf:type owl:DatatypeProperty ;
              rdfs:domain :AllergyCondition ;
              rdfs:range xsd:string ;
              rdfs:label "allergen Name"@en ,
                         "ชื่อสารก่อภูมิแพ้"@th .


###  http://www.example.org/herbmedicine#approvedBy
:approvedBy rdf:type owl:DatatypeProperty ;
            rdfs:domain :HerbMedicine ;
            rdfs:range xsd:string ;
            rdfs:label "approved By"@en ,
                       "อนุมัติโดย"@th .


###  http://www.example.org/herbmedicine#dosageInstruction
:dosageInstruction rdf:type owl:DatatypeProperty ;
                   rdfs:domain :DosageGuideline ;
                   rdfs:range xsd:string ;
                   rdfs:label "dosage Instruction"@en ,
                              "คำแนะนำการใช้ยา"@th .


###  http://www.example.org/herbmedicine#frequencyDescription
:frequencyDescription rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Frequency ;
                      rdfs:range xsd:string ;
                      rdfs:label "frequency description"@en ,
                                 "รายละเอียดความถี่"@th .


###  http://www.example.org/herbmedicine#maxAge
:maxAge rdf:type owl:DatatypeProperty ;
        rdfs:domain :AgeCondition ;
        rdfs:range xsd:integer ;
        rdfs:label "maximum Age"@en ,
                   "อายุสูงสุด"@th .


###  http://www.example.org/herbmedicine#maxDose
:maxDose rdf:type owl:DatatypeProperty ;
         rdfs:domain :DosageGuideline ;
         rdfs:range xsd:decimal ;
         rdfs:label "maximum Dose"@en ,
                    "ขนาดยาสูงสุด"@th .


###  http://www.example.org/herbmedicine#minAge
:minAge rdf:type owl:DatatypeProperty ;
        rdfs:domain :AgeCondition ;
        rdfs:range xsd:integer ;
        rdfs:comment "The minimum age (in years) for using the medicine."@en ;
        rdfs:label "minimum Age"@en ,
                   "อายุต่ำสุด"@th .


###  http://www.example.org/herbmedicine#minDose
:minDose rdf:type owl:DatatypeProperty ;
         rdfs:domain :DosageGuideline ;
         rdfs:range xsd:decimal ;
         rdfs:label "minimum Dose"@en ,
                    "ขนาดยาต่ำสุด"@th .


###  http://www.example.org/herbmedicine#name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain owl:Thing ;
      rdfs:range xsd:string ;
      rdfs:label "name"@en ,
                 "ชื่อ"@th .


###  http://www.example.org/herbmedicine#nameThai
:nameThai rdf:type owl:DatatypeProperty ;
          rdfs:domain owl:Thing ;
          rdfs:range xsd:string ;
          rdfs:label "Thai name"@en ,
                     "ชื่อภาษาไทย"@th .


###  http://www.example.org/herbmedicine#quantity
:quantity rdf:type owl:DatatypeProperty ;
          rdfs:domain :FormulaComponent ;
          rdfs:range xsd:decimal ;
          rdfs:comment "The numeric amount of the ingredient in the formula."@en ;
          rdfs:label "quantity"@en ,
                     "ปริมาณ"@th .


###  http://www.example.org/herbmedicine#timesPerDay
:timesPerDay rdf:type owl:DatatypeProperty ;
             rdfs:domain :Frequency ;
             rdfs:range xsd:integer ;
             rdfs:label "times Per Day"@en ,
                        "ครั้งต่อวัน"@th .


###  http://www.example.org/herbmedicine#timingDescription
:timingDescription rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Timing ;
                   rdfs:range xsd:string ;
                   rdfs:label "timing description"@en ,
                              "รายละเอียดเวลา"@th ;
                   skos:example "ก่อนอาหาร, หลังอาหาร, ก่อนนอน" .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/herbmedicine#AgeCondition
:AgeCondition rdf:type owl:Class ;
              rdfs:subClassOf :PatientCondition ;
              rdfs:comment "Age-related constraints for medicine use, defined by minimum and maximum age."@en ;
              rdfs:label "Age Condition"@en ,
                         "เงื่อนไขอายุ"@th .


###  http://www.example.org/herbmedicine#AllergyCondition
:AllergyCondition rdf:type owl:Class ;
                  rdfs:subClassOf :PatientCondition ;
                  rdfs:comment "An allergic response that contraindicates use of a particular herb or medicine."@en ;
                  rdfs:label "Allergy Condition"@en ,
                             "ภาวะแพ้ยา/สมุนไพร"@th .


###  http://www.example.org/herbmedicine#Caution
:Caution rdf:type owl:Class ;
         rdfs:subClassOf :SafetyAlert ;
         rdfs:comment "A warning to use the medicine carefully under certain conditions."@en ;
         rdfs:label "Caution"@en ,
                    "ข้อควรระวัง"@th .


###  http://www.example.org/herbmedicine#Contraindication
:Contraindication rdf:type owl:Class ;
                  rdfs:subClassOf :SafetyAlert ;
                  rdfs:comment "Conditions or factors that serve as absolute reasons to withhold use of the medicine."@en ;
                  rdfs:label "Contraindication"@en ,
                             "ข้อห้ามใช้"@th .


###  http://www.example.org/herbmedicine#Disease
:Disease rdf:type owl:Class ;
         rdfs:subClassOf :MedicalCondition ;
         rdfs:comment "A specific illness or disease."@en ;
         rdfs:label "Disease"@en ,
                    "โรค"@th .


###  http://www.example.org/herbmedicine#DosageForm
:DosageForm rdf:type owl:Class ;
            rdfs:comment "The physical form in which a medicine is administered (tablet, capsule, decoction, etc.)."@en ;
            rdfs:label "Dosage Form"@en ,
                       "รูปแบบยา"@th .


###  http://www.example.org/herbmedicine#DosageGuideline
:DosageGuideline rdf:type owl:Class ;
                 rdfs:comment "Prescribing information defining how a medicine should be administered."@en ;
                 rdfs:label "Dosage Guideline"@en ,
                            "แนวทางการใช้ยา"@th .


###  http://www.example.org/herbmedicine#FormulaComponent
:FormulaComponent rdf:type owl:Class ;
                  rdfs:comment "An individual ingredient entry in a herbal medicine formula, specifying the herb, plant part used, and quantity."@en ;
                  rdfs:label "Formula Component"@en ,
                             "ส่วนประกอบสูตรยา"@th .


###  http://www.example.org/herbmedicine#Frequency
:Frequency rdf:type owl:Class ;
           rdfs:comment "The number of times medicine should be administered per day or per period."@en ;
           rdfs:label "Frequency"@en ,
                      "ความถี่"@th .


###  http://www.example.org/herbmedicine#GroupMedicine
:GroupMedicine rdf:type owl:Class ;
               rdfs:comment "A category or group that contains one or more herb medicines."@en ;
               rdfs:label "Group Medicine"@en ,
                          "กลุ่มยา"@th .


###  http://www.example.org/herbmedicine#Herb
:Herb rdf:type owl:Class ;
      rdfs:comment "A plant or plant-derived substance used in herbal medicine."@en ;
      rdfs:label "Herb"@en ,
                 "สมุนไพร"@th .


###  http://www.example.org/herbmedicine#HerbMedicine
:HerbMedicine rdf:type owl:Class ;
              rdfs:comment "A medicinal product composed of herbal components used for therapeutic purposes."@en ;
              rdfs:label "Herb Medicine"@en ,
                         "ยาสมุนไพร"@th .


###  http://www.example.org/herbmedicine#MedicalCondition
:MedicalCondition rdf:type owl:Class ;
                  rdfs:comment "A health condition, disease, or symptom that a herb medicine treats."@en ;
                  rdfs:label "Medical Condition"@en ,
                             "สภาวะทางการแพทย์"@th .


###  http://www.example.org/herbmedicine#PatientCondition
:PatientCondition rdf:type owl:Class ;
                  rdfs:comment "A characteristic or state of the patient relevant to drug safety and dosing."@en ;
                  rdfs:label "Patient Condition"@en ,
                             "สภาวะของผู้ป่วย"@th .


###  http://www.example.org/herbmedicine#PhysiologicalState
:PhysiologicalState rdf:type owl:Class ;
                    rdfs:subClassOf :PatientCondition ;
                    rdfs:comment "A physiological state of the patient such as pregnancy or lactation."@en ;
                    rdfs:label "Physiological State"@en ,
                               "สภาวะทางสรีรวิทยา"@th ;
                    skos:example "ตั้งครรภ์ (Pregnancy), ให้นมบุตร (Lactation), มีประจำเดือน (Menstruation)" .


###  http://www.example.org/herbmedicine#PlantPart
:PlantPart rdf:type owl:Class ;
           rdfs:comment "The specific part of a plant (root, leaf, bark, seed, etc.) used in a formula."@en ;
           rdfs:label "Plant Part"@en ,
                      "ส่วนของพืช"@th .


###  http://www.example.org/herbmedicine#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:comment "A warning or precaution associated with a herb medicine."@en ;
             rdfs:label "Safety Alert"@en ,
                        "การแจ้งเตือนความปลอดภัย"@th .


###  http://www.example.org/herbmedicine#Symptom
:Symptom rdf:type owl:Class ;
         rdfs:subClassOf :MedicalCondition ;
         rdfs:comment "A clinical sign or symptom associated with a medical condition."@en ;
         rdfs:label "Symptom"@en ,
                    "อาการ"@th .


###  http://www.example.org/herbmedicine#Timing
:Timing rdf:type owl:Class ;
        rdfs:comment "The timing of medicine administration relative to meals or time of day."@en ;
        rdfs:label "Timing"@en ,
                   "เวลาในการรับประทาน"@th .


###  http://www.example.org/herbmedicine#UnitOfMeasurement
:UnitOfMeasurement rdf:type owl:Class ;
                   rdfs:comment "A unit used to express quantity or dosage (e.g., grams, milligrams, teaspoons)."@en ;
                   rdfs:label "Unit Of Measurement"@en ,
                              "หน่วยวัด"@th .


#################################################################
#    Individuals (ABox)
#################################################################

### GroupMedicine Instances
:group_ยารักษากลุ่มอาการทางระบบไหลเวียนโลหิต  rdf:type :GroupMedicine ;
    :name "ยารักษากลุ่มอาการทางระบบไหลเวียนโลหิต"^^xsd:string .

:group_กลุ่มยาแก้ลมกองละเอียด  rdf:type :GroupMedicine ;
    :name "กลุ่มยาแก้ลมกองละเอียด"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบไหลเวียนโลหิต  :containsMedicine  :group_กลุ่มยาแก้ลมกองละเอียด .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  rdf:type :GroupMedicine ;
    :name "ยารักษากลุ่มอาการทางระบบทางเดินอาหาร"^^xsd:string .

:group_กลุ่มยาขับลมบรรเทาอาการท้องอืดท้องเฟ้อ  rdf:type :GroupMedicine ;
    :name "กลุ่มยาขับลมบรรเทาอาการท้องอืดท้องเฟ้อ"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  :containsMedicine  :group_กลุ่มยาขับลมบรรเทาอาการท้องอืดท้องเฟ้อ .

:group_กลุ่มยาบรรเทาอาการท้องผูก  rdf:type :GroupMedicine ;
    :name "กลุ่มยาบรรเทาอาการท้องผูก"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  :containsMedicine  :group_กลุ่มยาบรรเทาอาการท้องผูก .

:group_กลุ่มยาบรรเทาอาการท้องเสีย  rdf:type :GroupMedicine ;
    :name "กลุ่มยาบรรเทาอาการท้องเสีย"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  :containsMedicine  :group_กลุ่มยาบรรเทาอาการท้องเสีย .

:group_กลุ่มยาบรรเทาริดสีดวงทวารหนัก  rdf:type :GroupMedicine ;
    :name "กลุ่มยาบรรเทาริดสีดวงทวารหนัก"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  :containsMedicine  :group_กลุ่มยาบรรเทาริดสีดวงทวารหนัก .

:group_กลุ่มยารักษาโรคในกระเพาะอาหาร  rdf:type :GroupMedicine ;
    :name "กลุ่มยารักษาโรคในกระเพาะอาหาร"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  :containsMedicine  :group_กลุ่มยารักษาโรคในกระเพาะอาหาร .

:group_กลุ่มยาบรรเทาอาการคลื่นไส้อาเจียน  rdf:type :GroupMedicine ;
    :name "กลุ่มยาบรรเทาอาการคลื่นไส้อาเจียน"^^xsd:string .

:group_ยารักษากลุ่มอาการทางระบบทางเดินอาหาร  :containsMedicine  :group_กลุ่มยาบรรเทาอาการคลื่นไส้อาเจียน .

:group_ยารักษากลุ่มอาการสูติศาสตร์นรีเวชวิทยา  rdf:type :GroupMedicine ;
    :name "ยารักษากลุ่มอาการสูติศาสตร์นรีเวชวิทยา"^^xsd:string .

:group_ยารักษากลุ่มอาการไข้  rdf:type :GroupMedicine ;
    :name "ยารักษากลุ่มอาการไข้"^^xsd:string .

:group_กลุ่มยาแก้ไข้_แก้ร้อนใน  rdf:type :GroupMedicine ;
    :name "กลุ่มยาแก้ไข้/ แก้ร้อนใน"^^xsd:string .

:group_ยารักษากลุ่มอาการไข้  :containsMedicine  :group_กลุ่มยาแก้ไข้_แก้ร้อนใน .

:group_ยารักษากลุ่มอาการของระบบทางเดินหายใจ  rdf:type :GroupMedicine ;
    :name "ยารักษากลุ่มอาการของระบบทางเดินหายใจ"^^xsd:string .

:group_กลุ่มยาบรรเทาอาการไอ__เสมหะ  rdf:type :GroupMedicine ;
    :name "กลุ่มยาบรรเทาอาการไอ / เสมหะ"^^xsd:string .

:group_ยารักษากลุ่มอาการของระบบทางเดินหายใจ  :containsMedicine  :group_กลุ่มยาบรรเทาอาการไอ__เสมหะ .

